{
  "name": "mobile",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "mobile/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "expo start",
        "cwd": "{workspaceRoot}/mobile",
        "forwardAllArgs": true
      },
      "continuous": true
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "expo export",
        "cwd": "{workspaceRoot}/mobile"
      }
    }
  }
}
